{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || (root.child('users').child(auth.uid).child('familyGroupId').val() != null && root.child('users').child(auth.uid).child('familyGroupId').val() == root.child('users').child($uid).child('familyGroupId').val()))",
        ".write": "auth != null && auth.uid == $uid && (
          !newData.exists() ||
          (
            (
              !newData.hasChild('familyGroupId') ||
              newData.child('familyGroupId').val() == null ||
              root.child('familyGroups').child(newData.child('familyGroupId').val()).child('memberIds').hasChild($uid)
            ) &&
            newData.child('claimsUpdatedAt').val() == data.child('claimsUpdatedAt').val() &&
            (
              newData.child('usageCounters/lastResetDate').val() != data.child('usageCounters/lastResetDate').val() ||
              (
                newData.child('usageCounters/listsCreated').val() >= data.child('usageCounters/listsCreated').val() &&
                newData.child('usageCounters/ocrProcessed').val() >= data.child('usageCounters/ocrProcessed').val() &&
                newData.child('usageCounters/urgentItemsCreated').val() >= data.child('usageCounters/urgentItemsCreated').val()
              )
            )
          )
        )",

        "usageCounters": {
          ".validate": "newData.hasChildren(['listsCreated', 'ocrProcessed', 'urgentItemsCreated', 'lastResetDate'])"
        }
      }
    },

    "familyGroups": {
      "$groupId": {
        ".read": "auth != null && data.child('memberIds').child(auth.uid).exists()",
        ".write": "auth != null && (
          (
            !data.exists() &&
            newData.child('memberIds').child(auth.uid).val() === true &&
            (!newData.hasChild('subscriptionTier') || newData.child('subscriptionTier').val() === 'free') &&
            !newData.hasChild('tierUpdatedAt')
          ) ||
          (data.child('memberIds').child(auth.uid).exists() && !newData.exists())
        )",

        "memberIds": {
          "$userId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && (
              (auth.uid == $userId && data.parent().child($userId).exists()) ||
              (root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid) &&
               root.child('familyGroups').child($groupId).child('joinRequests').child($userId).exists() &&
               newData.val() === true)
            )",
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        },

        "joinRequests": {
          ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
          "$userId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && (
              auth.uid == $userId ||
              root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)
            )",
            ".validate": "!newData.exists() || (
              newData.hasChildren(['userId', 'groupId', 'displayName', 'email', 'requestedAt', 'status']) &&
              newData.child('groupId').isString() &&
              newData.child('requestedAt').isNumber() &&
              newData.child('status').val().matches(/^(pending|approved|rejected)$/)
            )"
          }
        },

        "subscriptionTier": {
          ".write": "auth != null && auth.token.admin === true"
        },

        "invitationCode": {
          ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
          ".validate": "newData.isString()"
        },

        "lists": {
          "$listId": {
            ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".validate": "newData.hasChildren(['name', 'createdBy', 'createdAt', 'familyGroupId']) && newData.child('createdAt').isNumber() && newData.child('createdAt').val() > 0 && newData.child('name').isString() && newData.child('createdBy').isString() && newData.child('familyGroupId').isString()"
          }
        },

        "items": {
          ".indexOn": ["listId"],
          "$itemId": {
            ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".validate": "newData.hasChildren(['name', 'listId', 'createdBy', 'checked']) && newData.child('name').isString() && newData.child('listId').isString() && newData.child('createdBy').isString() && newData.child('checked').isBoolean()"
          }
        },

        "priceHistory": {
          ".indexOn": ["recordedAt"],
          "$recordId": {
            ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".validate": "newData.hasChildren(['id', 'itemName', 'price', 'recordedAt', 'familyGroupId']) && newData.child('price').isNumber() && newData.child('recordedAt').isNumber() && newData.child('itemName').isString() && newData.child('familyGroupId').isString()"
          }
        },

        "storeLayouts": {
          "$layoutId": {
            ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
            ".validate": "newData.hasChildren(['storeName', 'categoryOrder', 'familyGroupId', 'createdBy', 'createdAt']) && newData.child('storeName').isString() && newData.child('familyGroupId').isString() && newData.child('createdBy').isString() && newData.child('categoryOrder').hasChildren()"
          }
        },

        "categoryHistory": {
          "$itemHash": {
            "$category": {
              ".read": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
              ".write": "auth != null && root.child('familyGroups').child($groupId).child('memberIds').hasChild(auth.uid)",
              ".validate": "newData.hasChildren(['category', 'usageCount', 'lastUsedAt', 'createdAt']) && newData.child('usageCount').isNumber() && newData.child('lastUsedAt').isNumber() && newData.child('createdAt').isNumber()"
            }
          }
        }
      }
    },

    "invitations": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || root.child('familyGroups').child(data.child('groupId').val()).child('memberIds').hasChild(auth.uid))",
        ".validate": "newData.hasChildren(['groupId', 'createdAt']) && newData.child('groupId').isString() && newData.child('createdAt').isNumber()"
      }
    },

    "urgentItems": {
      "$familyGroupId": {
        ".indexOn": ["createdAt"],
        ".read": "auth != null && root.child('familyGroups').child($familyGroupId).child('memberIds').hasChild(auth.uid)",
        ".write": "auth != null && root.child('familyGroups').child($familyGroupId).child('memberIds').hasChild(auth.uid)",
        "$itemId": {
          ".validate": "newData.hasChildren(['name', 'createdBy', 'createdAt', 'familyGroupId']) && newData.child('createdAt').isNumber() && newData.child('createdAt').val() > 0 && newData.child('name').isString() && newData.child('createdBy').isString() && newData.child('familyGroupId').isString()"
        }
      }
    }
  }
}
